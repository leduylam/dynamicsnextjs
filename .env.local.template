# API Endpoint - Laravel backend admin-vgd (1 backend chung).
# Local: http://localhost:80 (admin-vgd qua nginx)
# Production: https://admin.vgd.vn
NEXT_PUBLIC_REST_API_ENDPOINT=http://localhost:80

# URL gốc cho site (ảnh, share link, SEO).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site (tenant) slug — scope public API về site DSC qua header X-Site-Id.
NEXT_PUBLIC_SITE_SLUG=dsc
